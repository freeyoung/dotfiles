# Personal interactive Zsh configuration.
#
# The fish-era configuration and migration snapshots are preserved in
# ~/zsh-backups. The ordered modules below keep related concerns together
# without altering the startup sequence or materially affecting latency.

[[ -o interactive ]] || return

typeset _zsh_rc_dir=${${(%):-%N}:A:h}
source "$_zsh_rc_dir/rc.d/10-environment.zsh"
source "$_zsh_rc_dir/rc.d/20-python.zsh"
source "$_zsh_rc_dir/rc.d/30-commands.zsh"
source "$_zsh_rc_dir/rc.d/40-completion.zsh"
source "$_zsh_rc_dir/rc.d/50-node-and-tools.zsh"
source "$_zsh_rc_dir/rc.d/60-prompt.zsh"
source "$_zsh_rc_dir/rc.d/70-plugins.zsh"
source "$_zsh_rc_dir/rc.d/80-interaction.zsh"
unset _zsh_rc_dir
